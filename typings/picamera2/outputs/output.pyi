from _typeshed import Incomplete

class Output:
    recording: bool
    needs_pacing: bool
    needs_add_stream: bool
    def __init__(self, pts=None) -> None: ...
    def start(self) -> None: ...
    def stop(self) -> None: ...
    def outputframe(
        self,
        frame,
        keyframe: bool = True,
        timestamp=None,
        packet=None,
        audio: bool = False,
    ) -> None: ...
    def outputtimestamp(self, timestamp) -> None: ...
    @property
    def ptsoutput(self): ...
    _ptsoutput: Incomplete
    @ptsoutput.setter
    def ptsoutput(self, file) -> None: ...
    def _add_stream(self, encoder_stream, *args, **kwargs) -> None: ...
